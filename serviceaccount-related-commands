# 1. Create the ServiceAccount
kubectl create sa dev-sa -n meta

# 2. Create the Role
kubectl create role dev-deploy-role -n meta --resource=deployments --verb=get,list,watch

# 3. Create the RoleBinding
kubectl create rolebinding dev-deploy-rb -n meta --role=dev-deploy-role --serviceaccount=meta:dev-sa

# 4. Update the Deployment to use the ServiceAccount
kubectl set serviceaccount deployment/dev-deployment dev-sa -n meta
